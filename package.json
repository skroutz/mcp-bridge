{
  "name": "mcp-bridge",
  "version": "0.1.12",
  "description": "Secure stdio-to-Streamable-HTTP MCP bridge for Claude Desktop.",
  "type": "module",
  "bin": {
    "mcp-bridge": "./index.js"
  },
  "files": [
    "index.js",
    "README.md",
    "mcpb",
    "scripts/build-mcpb.mjs",
    "scripts/check-stdio-runtime.mjs",
    "scripts/emulate-mcpb.mjs"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build:mcpb": "node ./scripts/build-mcpb.mjs",
    "check": "node --check index.js && node --check scripts/build-mcpb.mjs && node --check scripts/check-stdio-runtime.mjs && node --check scripts/emulate-mcpb.mjs && node scripts/check-stdio-runtime.mjs",
    "emulate:mcpb": "node ./scripts/emulate-mcpb.mjs",
    "pack:dry-run": "npm --cache .npm-cache pack --dry-run",
    "start": "node ./index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "streamable-http",
    "stdio"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  }
}
